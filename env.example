# ─────────────────────────────────────────────────────────────
# SigLearn — Environment Variables
# Copy this file to .env and fill in your values.
# For HF Spaces: add these as Repository Secrets in Space settings.
# ─────────────────────────────────────────────────────────────

# ── HuggingFace Token (free tier works) ──────────────────────
# Get yours at: https://huggingface.co/settings/tokens
# Needed for Mistral-7B Inference API
HF_TOKEN=your_huggingface_token_here

# ── Dataset Paths ─────────────────────────────────────────────
# Point these to your downloaded dataset folders.
# Default (relative): ./data/...  — put datasets in the data/ folder
# Or use absolute paths:

# MIT-BIH Arrhythmia Database
# Download from: https://physionet.org/content/mitdb/1.0.0/
MITBIH_PATH=./data/mit-bih-arrhythmia-database-1.0.0

# Ninapro DB1
# Download from: https://ninapro.hevs.ch/instructions/DB1.html
NINAPRO_PATH=./data/ninapro-db1

# BIDMC PPG and Respiration Dataset
# Download from: https://physionet.org/content/bidmc/1.0.0/
BIDMC_PATH=./data/bidmc-ppg-and-respiration-dataset-1.0.0

# EEG: No path needed — MNE downloads automatically (~2MB per run)
# Cached at: ~/mne_data/MNE-eegbci-data/
